<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================= -->
    <!-- Tree View -->
    <!-- ========================= -->
    <record id="view_purchase_request_documentation_tree" model="ir.ui.view">
        <field name="name">purchase.request.documentation.tree</field>
        <field name="model">purchase.request.documentation</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="file_name"/>
                <field name="link_url"/>
                <field name="created_by"/>
                <field name="created_on"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View -->
    <!-- ========================= -->
    <record id="view_purchase_request_documentation_form" model="ir.ui.view">
        <field name="name">purchase.request.documentation.form</field>
        <field name="model">purchase.request.documentation</field>
        <field name="arch" type="xml">
            <form string="Documentation">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="link_url" placeholder="https://..."/>
                    </group>

                    <group string="Audit">
                        <field name="created_by" readonly="1"/>
                        <field name="created_on" readonly="1"/>
                    </group>

                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_purchase_request_documentation" model="ir.actions.act_window">
        <field name="name">Documentation</field>
        <field name="res_model">purchase.request.documentation</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Documentation -->
    <menuitem id="menu_purchase_request_documentation"
              name="Documentation"
              parent="demande_d_achat.menu_purchase_request_root"
              action="demande_d_achat.action_purchase_request_documentation"
              sequence="20"/>

</odoo>
